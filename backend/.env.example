# ──────────────────────────────────────────────
# Database
# Use the pooled connection string for DATABASE_URL (runtime)
# Use the direct (non-pooled) connection string for DIRECT_URL (Prisma migrations)
# Both are available from your Neon / Supabase / Render dashboard
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@pooler-host:5432/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@direct-host:5432/dbname?sslmode=require

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production

# ──────────────────────────────────────────────
# LLM (Google Gemini)
# ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ──────────────────────────────────────────────
# Email (Resend)
# ──────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=onboarding@resend.dev

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SCORE_THRESHOLD=80
FRONTEND_URL=http://localhost:5173
